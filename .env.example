# Power Agent - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore

# ========================================
# Claude AI (Anthropic)
# ========================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========================================
# Supabase Database
# ========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Alternative key names (for compatibility)
SUPABASE_KEY=your_supabase_service_role_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ========================================
# Tavily Web Search
# ========================================
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ========================================
# Google Cloud Platform
# ========================================
# Your GCP project ID
GCP_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud credentials (JSON format)
# OPTION 1: Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json

# OPTION 2: Inline JSON (for Cloud Run deployment)
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"..."}'

# ========================================
# Server Configuration
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# Frontend URLs (for CORS)
# ========================================
# Your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app

# ========================================
# E2B Configuration (Legacy - Optional)
# ========================================
# E2B_API_KEY=your_e2b_api_key_here

# ========================================
# Notes
# ========================================
# 1. NEVER commit this file with real values to git
# 2. For production deployment on Cloud Run:
#    - Set these as environment variables in Cloud Run console
#    - OR use Secret Manager for sensitive values
# 3. For Vercel deployment:
#    - Set as environment variables in Vercel dashboard
#    - Use NEXT_PUBLIC_ prefix for client-side variables
# 4. Supabase ANON_KEY is safe to expose in frontend (read-only)
# 5. Supabase SERVICE_ROLE_KEY must NEVER be exposed to frontend
